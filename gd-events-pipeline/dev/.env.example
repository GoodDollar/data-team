# ============================================================================
# Required
# ============================================================================

# HyperSync API token — get from https://app.envio.dev/api-tokens
ENVIO_API_TOKEN=

# ============================================================================
# GCP (optional — defaults shown)
# ============================================================================

GCP_PROJECT_ID=gooddollar
DATASET_ID=BlockchainEvents

# ============================================================================
# Logging
# ============================================================================

LOG_FILE=pipeline.log
LOG_LEVEL=INFO

# ============================================================================
# Retry posture
# ============================================================================

BQ_RETRIES=3
LOAD_RETRIES=3
HYPERSYNC_RETRIES=5

# ============================================================================
# Chunking
# ============================================================================

# Target rows per staging load chunk. Actual chunks are block-aligned so
# can be slightly larger if a block straddles the boundary.
CHUNK_SIZE_LOAD_TARGET=50000

# Block-range window per verify chunk. Larger = fewer BQ/HyperSync calls
# but coarser mismatch localization.
CHUNK_SIZE_VERIFY_BLOCKS=100000

# ============================================================================
# Concurrency
# ============================================================================

# Max concurrent (contract, network) fetch streams in flight. Writes to
# the same production table are still serialized regardless.
FETCH_CONCURRENCY=4

# ============================================================================
# Verification window
# ============================================================================

# How many days back to verify in daily mode. Should exceed the deepest
# reorg depth you care about.
VERIFY_WINDOW_DAYS=7

# ============================================================================
# Pipeline lock
# ============================================================================

# Lock TTL in ms. A run holding the lock longer than this can have it
# stolen by a subsequent run. Default: 6 hours.
LOCK_TTL_MS=21600000

# ============================================================================
# Infrastructure table names (rarely changed)
# ============================================================================

UNKNOWN_EVENTS_TABLE=UnknownEvents
INGESTION_STATUS_TABLE=IngestionStatus
PIPELINE_LOCKS_TABLE=PipelineLocks
